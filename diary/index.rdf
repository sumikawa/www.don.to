  <item rdf:about="2023/1028-haloween/">
            <title>2023/10/28: 会社イベント</title>
        <link>https://www.don.to/diary/2023/1028-haloween/</link>
        <description><![CDATA[<p>会社イベントへ娘と二人で参加。</p>

<p><a href="https://www.don.to/diary/600/img_9334.jpg" class="image swipe"><img src="https://www.don.to/diary/96/img_9334.jpg" srcset="https://www.don.to/diary/96/img_9334.jpg 1x, https://www.don.to/diary/192/img_9334.jpg 2x" height="96" alt="img_9334"/></a>
<a href="https://www.don.to/diary/hdimg_9335.mp4" class="video swipe"><img src="https://www.don.to/diary/video/96/hdimg_9335.jpg" height="96" alt="hdimg_9335" /></a>
<a href="https://www.don.to/diary/600/img_9336.jpg" class="image swipe"><img src="https://www.don.to/diary/96/img_9336.jpg" srcset="https://www.don.to/diary/96/img_9336.jpg 1x, https://www.don.to/diary/192/img_9336.jpg 2x" height="96" alt="img_9336"/></a>
<a href="https://www.don.to/diary/600/img_9337.jpg" class="image swipe"><img src="https://www.don.to/diary/96/img_9337.jpg" srcset="https://www.don.to/diary/96/img_9337.jpg 1x, https://www.don.to/diary/192/img_9337.jpg 2x" height="96" alt="img_9337"/></a>
<a href="https://www.don.to/diary/hdimg_9339.mp4" class="video swipe"><img src="https://www.don.to/diary/video/96/hdimg_9339.jpg" height="96" alt="hdimg_9339" /></a>
